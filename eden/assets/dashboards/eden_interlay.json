    {
      "id": 3000000000000040,
      "definition": {
        "title": "Direct Mode",
        "show_title": true,
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "id": 3000000000000041,
            "definition": {
              "type": "note",
              "content": "**Safe vs Unsafe.** Safe = lane-pooled stateless RESP arrays. Unsafe = pinned raw backend stream after the client sends connection-stateful commands (transactions, blocking ops, pub/sub). Promotion is one-way until disconnect. Watch the unsafe count \u2014 high counts cap Redis `maxclients` headroom.",
              "background_color": "gray",
              "font_size": "12",
              "text_align": "left",
              "vertical_align": "top",
              "show_tick": false,
              "tick_pos": "50%",
              "tick_edge": "left",
              "has_padding": true
            },
            "layout": {
              "x": 0,
              "y": 0,
              "width": 3,
              "height": 6
            }
          },
          {
            "id": 3000000000000042,
            "definition": {
              "title": "Active connections by mode",
              "title_size": "16",
              "title_align": "left",
              "show_legend": true,
              "legend_layout": "auto",
              "legend_columns": [
                "avg",
                "max",
                "value"
              ],
              "type": "timeseries",
              "requests": [
                {
                  "formulas": [
                    {
                      "alias": "Safe",
                      "formula": "safe"
                    },
                    {
                      "alias": "Unsafe (pinned)",
                      "formula": "unsafe"
                    }
                  ],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "safe",
                      "query": "sum:eden.proxy.direct_safe_connections_active{$interlay_uuid,$endpoint_uuid,$endpoint_kind,$eden_node_uuid}"
                    },
                    {
                      "data_source": "metrics",
                      "name": "unsafe",
                      "query": "sum:eden.proxy.direct_unsafe_connections_active{$interlay_uuid,$endpoint_uuid,$endpoint_kind,$eden_node_uuid}"
                    }
                  ],
                  "response_format": "timeseries",
                  "style": {
                    "palette": "cool",
                    "order_by": "values",
                    "line_type": "solid",
                    "line_width": "normal"
                  },
                  "display_type": "area"
                }
              ],
              "yaxis": {
                "label": "Connections",
                "scale": "linear",
                "include_zero": true
              }
            },
            "layout": {
              "x": 3,
              "y": 0,
              "width": 5,
              "height": 3
            }
          },
          {
            "id": 3000000000000043,
            "definition": {
              "title": "Promotion rate (safe\u2192unsafe) by reason",
              "title_size": "16",
              "title_align": "left",
              "show_legend": true,
              "legend_layout": "auto",
              "legend_columns": [
                "avg",
                "max",
                "value"
              ],
              "type": "timeseries",
              "requests": [
                {
                  "formulas": [
                    {
                      "alias": "Promotions/sec",
                      "formula": "promo"
                    }
                  ],
                  "queries": [
                    {
