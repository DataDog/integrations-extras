{
  "version": 2,
  "title": "",
  "tags": [
    "integration:ziris"
  ],
  "definition": {
    "name": "Mainframe CPU Contention Monitor",
    "type": "query alert",
    "query": "max(last_15m):max:ziris.zos.cpu.in_ready_work_queue_contention{*} by {host.name}.fill(linear) > 0.59",
    "message": "This monitor will trigger when CPU contention increases above 60% for one or more logical partitions (LPARs) on mainframe platforms.",
    "tags": [
      "mainframe-cpu"
    ],
    "options": {
      "thresholds": {
        "critical": 0.59,
        "warning": 0.5
      },
      "notify_audit": false,
      "on_missing_data": "default",
      "include_tags": true,
      "new_group_delay": 60,
      "silenced": {}
    }
  },
  "created_at": "2025-10-27",
  "last_updated_at": "2026-05-06",
  "description": ""
}