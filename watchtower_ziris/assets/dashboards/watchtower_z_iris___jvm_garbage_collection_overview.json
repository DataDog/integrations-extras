                  "queries": [
                    {
                      "name": "query2",
                      "query": "avg:zos.jvm.memory.limit{$service.name, $host} by {service}",
                      "aggregator": "avg",
                      "data_source": "metrics"
                    },
                    {
                      "name": "query1",
                      "query": "avg:zos.jvm.memory.committed_after_last_gc{$host, $service.name} by {service}",
