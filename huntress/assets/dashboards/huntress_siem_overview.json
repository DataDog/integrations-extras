              "requests": [
                {
                  "response_format": "timeseries",
                  "queries": [
                    {
                      "name": "limit",
                      "data_source": "metrics",
                      "query": "avg:huntress.siem.api_call_limit{*}"
                    },
                    {
                      "name": "remaining",
                      "data_source": "metrics",
                      "query": "avg:huntress.siem.api_call_remaining{*}"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "limit",
                      "alias": "Limit"
                    },
                    {
                      "formula": "remaining",
                      "alias": "Remaining"
                    }
                  ],
                  "display_type": "line",
                  "style": {
                    "palette": "cool",
                    "line_type": "solid",
                    "line_width": "normal"
                  }
                }
              ],
              "markers": [
                {
                  "value": "y = 10",
                  "display_type": "error dashed",
                  "label": "Low remaining (< 10)"
                }
              ]
            },
            "layout": {
              "x": 10,
              "y": 2,
