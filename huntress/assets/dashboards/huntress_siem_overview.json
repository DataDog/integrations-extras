              "requests": [
                {
                  "response_format": "scalar",
                  "queries": [
                    {
                      "name": "query1",
                      "data_source": "metrics",
                      "query": "sum:huntress.siem.pages_fetched{*}",
                      "aggregator": "last"
                    }
