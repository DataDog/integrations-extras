## All options defined here are available to all instances.
#
init_config:

    ## @param service - string - optional
    ## Attach the tag `service:<SERVICE>` to every metric, event, and service check emitted by this integration.
    ##
    ## Additionally, this sets the default `service` for every log source.
    #
    # service: <SERVICE>

## Every instance is scheduled independently of the others.
#
instances:

  -
    ## @param resources - list of strings - optional
    ## Optional list of PSI resources to collect. If omitted, all three (cpu, memory, io)
    ## are collected. Restrict the list to silence resources whose pressure is
    ## permanently elevated for legitimate reasons (e.g., a batch-compute host where
    ## memory pressure during job ramp-up is normal, or a database host with sustained
    ## high I/O), or to skip a file that is masked by container/security policy.
    ## Allowed values: cpu, memory, io.
    #
    # resources:
    #   - cpu
    #   - memory
    #   - io

    ## @param cgroup_roots - list of strings - optional
    ## Optional list of cgroup v2 slices to walk for per-cgroup PSI metrics.
    ## When empty (default) only host-wide PSI is collected. When set, the check
    ## walks each listed slice under cgroupfs_path and emits metrics under the
    ## system.pressure.cgroup.* namespace tagged with cgroup_path and cgroup_root.
    ## Per-cgroup PSI requires the unified cgroup v2 hierarchy (most modern
    ## systemd-based distros on kernel 5.2+). Common values:
    ##   - system.slice   - systemd services
    ##   - user.slice     - user-session cgroups
    ##   - kubepods.slice - Kubernetes pods (path varies by k8s setup)
    ## Cardinality scales linearly with the number of cgroups; see
    ## cgroup_max_count to cap.
    #
    # cgroup_roots:
    #   - system.slice

    ## @param cgroupfs_path - string - optional - default: /sys/fs/cgroup
    ## Path to the cgroup v2 filesystem root. Defaults to /sys/fs/cgroup, which is
    ## correct on standard hosts. Override for unusual mount points or for
    ## containerized agents that bind-mount the host cgroupfs elsewhere.
    #
    # cgroupfs_path: /sys/fs/cgroup

    ## @param cgroup_max_depth - integer - optional - default: 2
    ## Maximum subdirectory depth to descend when walking each cgroup root.
    ## Default 2 (the root itself and one level of children, which is enough
    ## for systemd's slice/service layout and most k8s pod-level analysis).
    ## Increase to see per-container metrics inside k8s pods (depth 3 or 4)
    ## at the cost of higher cardinality.
    #
    # cgroup_max_depth: 2

    ## @param cgroup_max_count - integer - optional - default: 200
    ## Maximum total number of cgroups to emit metrics for per check run.
    ## Defaults to 200. Prevents cardinality blow-up on hosts running
    ## thousands of cgroups; the check logs a warning when this cap is hit.
    #
    # cgroup_max_count: 200

    ## @param tags - list of strings - optional
    ## A list of tags to attach to every metric and service check emitted by this instance.
    ##
    ## Learn more about tagging at https://docs.datadoghq.com/tagging
    #
    # tags:
    #   - <KEY_1>:<VALUE_1>
    #   - <KEY_2>:<VALUE_2>

    ## @param service - string - optional
    ## Attach the tag `service:<SERVICE>` to every metric, event, and service check emitted by this integration.
    ##
    ## Overrides any `service` defined in the `init_config` section.
    #
    # service: <SERVICE>

    ## @param min_collection_interval - number - optional - default: 15
    ## This changes the collection interval of the check. For more information, see:
    ## https://docs.datadoghq.com/developers/write_agent_check/#collection-interval
    #
    # min_collection_interval: 15

    ## @param empty_default_hostname - boolean - optional - default: false
    ## This forces the check to send metrics with no hostname.
    ##
    ## This is useful for cluster-level checks.
    #
    # empty_default_hostname: false

    ## @param metric_patterns - mapping - optional
    ## A mapping of metrics to include or exclude, with each entry being a regular expression.
    ##
    ## Metrics defined in `exclude` will take precedence in case of overlap.
    #
    # metric_patterns:
    #   include:
    #   - <INCLUDE_REGEX>
    #   exclude:
    #   - <EXCLUDE_REGEX>
